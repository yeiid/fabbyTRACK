---
const pages = [
  { href: '/master', label: 'Panel', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { href: '/master/users', label: 'Usuarios', icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z' },
  { href: '/master/exercises', label: 'Ejercicios', icon: 'M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z' },
  { href: '/master/routines', label: 'Rutinas', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' },
  { href: '/master/nutrition', label: 'Nutricion', icon: 'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4' },
  { href: '/master/assign', label: 'Asignar', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
];

const currentUrl = Astro.url.pathname;
const session = Astro.cookies.get('user_session')?.json();
const userName = session?.name || '';
const userInitial = userName ? userName.charAt(0).toUpperCase() : 'M';
---

<nav class="master-nav glass">
  <div class="nav-brand">
    <span class="nav-logo">F</span>
    <span class="nav-title">FabbyTRACK</span>
  </div>
  <button id="nav-toggle" class="nav-toggle" aria-label="Menu">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
  </button>
  <div class="nav-links" id="nav-links">
    {pages.map(p => {
      const isActive = currentUrl === p.href || (p.href !== '/master' && currentUrl.startsWith(p.href));
      return (
        <a href={p.href} class={`nav-link${isActive ? ' active' : ''}`}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d={p.icon}/></svg>
          <span>{p.label}</span>
        </a>
      );
    })}
  </div>
  <div class="nav-user">
    <span class="nav-user-name">{userName}</span>
    <div class="nav-avatar">{userInitial}</div>
    <button id="nav-logout" class="nav-logout-btn" title="Cerrar Sesion">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4m7 14l5-5-5-5m5 5H9"/></svg>
    </button>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle');
  const links = document.getElementById('nav-links');

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    links?.classList.toggle('open');
  });

  document.addEventListener('click', (e) => {
    if (links?.classList.contains('open') && !links?.contains(e.target as Node) && e.target !== toggle) {
      links?.classList.remove('open');
    }
  });

  links?.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', () => links?.classList.remove('open'));
  });

  document.getElementById('nav-logout')?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/login';
  });
</script>

<style>
  .master-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--spacing-xl);
    height: 60px;
    border-bottom: 1px solid var(--border-subtle);
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    flex-shrink: 0;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .nav-logo {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--primary-500), var(--accent-400));
    border-radius: 8px;
    font-weight: 800;
    font-size: 1rem;
    color: white;
    font-family: 'Outfit', sans-serif;
  }

  .nav-title {
    font-weight: 700;
    font-size: var(--text-base);
    font-family: 'Outfit', sans-serif;
    background: linear-gradient(135deg, var(--text-primary), var(--primary-500));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: none;
  }

  .nav-toggle {
    display: none;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    transition: all var(--transition-fast);
    margin-left: auto;
    margin-right: var(--spacing-sm);
  }

  .nav-toggle:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-primary);
  }

  .nav-toggle svg {
    width: 22px;
    height: 22px;
  }

  .nav-links {
    display: flex;
    gap: 2px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-link.active {
    color: var(--primary-500);
    background: rgba(124, 58, 237, 0.1);
  }

  .nav-user {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .nav-user-name {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    display: none;
  }

  .nav-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--primary-600);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: var(--text-sm);
    color: white;
  }

  .nav-logout-btn {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    transition: all var(--transition-fast);
  }

  .nav-logout-btn:hover {
    color: var(--danger-500);
    background: rgba(239, 68, 68, 0.1);
  }

  @media (min-width: 900px) {
    .nav-title { display: block; }
    .nav-user-name { display: block; }
  }

  @media (min-width: 769px) {
    .nav-toggle { display: none !important; }
    .nav-links { display: flex !important; }
  }

  @media (max-width: 768px) {
    .master-nav {
      padding: 0 var(--spacing-md);
      height: 52px;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: rgba(15, 15, 26, 0.98);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-subtle);
      padding: var(--spacing-sm);
      gap: 2px;
      max-height: 80vh;
      overflow-y: auto;
      box-shadow: 0 12px 24px rgba(0, 0, 0, 0.4);
    }

    .nav-links.open {
      display: flex;
    }

    .nav-link {
      padding: 0.75rem var(--spacing-md);
      font-size: var(--text-sm);
      border-radius: var(--radius-sm);
      width: 100%;
    }

    .nav-link svg {
      width: 18px;
      height: 18px;
    }
  }
</style>
