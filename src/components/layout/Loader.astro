---
interface Props {
  size?: 'sm' | 'md' | 'lg';
}

const { size = 'md' } = Astro.props;
---

<div class={`loader loader-${size}`} aria-label="Cargando"></div>

<style>
  .loader {
    border: 3px solid var(--border-subtle);
    border-top-color: var(--primary-500);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  .loader-sm { width: 20px; height: 20px; }
  .loader-md { width: 32px; height: 32px; }
  .loader-lg { width: 48px; height: 48px; border-width: 4px; }
</style>
