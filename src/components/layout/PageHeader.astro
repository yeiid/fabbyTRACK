---
interface Props {
  title: string;
  href?: string;
  linkText?: string;
}

const { title, href, linkText = 'Volver' } = Astro.props;
---

<header class="page-header">
  <div class="header-content">
    {href && (
      <a href={href} class="btn btn-outline btn-sm">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        {linkText}
      </a>
    )}
    <h1 class="gradient-text">{title}</h1>
  </div>
  <slot />
</header>
