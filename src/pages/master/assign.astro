---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MasterNav from '../../components/layout/MasterNav.astro';
import PageHeader from '../../components/layout/PageHeader.astro';
import '../../styles/master-assign.css';

const session = Astro.cookies.get('user_session')?.json();
if (!session || session.role !== 'master') {
	return Astro.redirect('/login');
}

const days = ['Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado', 'Domingo'];
const mealTypes = [
	{ id: 'breakfast', label: 'Desayuno' },
	{ id: 'lunch', label: 'Almuerzo' },
	{ id: 'snack', label: 'Snack' },
	{ id: 'dinner', label: 'Cena' },
];
---

<BaseLayout title="Asignar Planes">
	<MasterNav />
	<main class="master-assign">
		<PageHeader title="Asignar Rutinas y Nutrición" href="/master" linkText="Volver" />

		<div id="assign-feedback" class="feedback-msg" style="display: none;"></div>

		<section class="assign-container glass-card">
			<div class="user-selector">
				<label for="user-select">Seleccionar Usuario:</label>
				<div class="user-select-wrapper">
					<input type="text" id="user-search" placeholder="Buscar usuario..." autocomplete="off">
					<select id="user-select">
						<option value="">Selecciona un usuario</option>
					</select>
				</div>
			</div>

			<div id="assignment-editor" class="editor" style="display: none;">
				<div class="tabs">
					<button class="tab-btn active" data-tab="nutrition">
						<span class="tab-icon">🥗</span>
						<span>Nutrición</span>
					</button>
					<button class="tab-btn" data-tab="routine">
						<span class="tab-icon">🏋️</span>
						<span>Rutina</span>
					</button>
				</div>

				<!-- Tab Nutrición -->
				<div id="nutrition-tab" class="tab-content active">
					<div class="tab-header">
						<h3 class="tab-title">Asignar Menú por Día</h3>
						<div class="tab-actions">
							<button class="btn btn-outline btn-sm copy-all-nutrition" title="Asignar el menú del Lunes a todos los días">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
								Copiar Lunes a Todos
							</button>
							<button class="btn btn-outline btn-sm clear-nutrition" title="Limpiar todas las asignaciones de nutrición">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
								Limpiar Todo
							</button>
						</div>
					</div>
					<div class="days-grid">
						{days.map(day => (
							<div class="day-card glass" data-day={day}>
								<h4>{day}</h4>
								<div class="meal-slots">
									{mealTypes.map(mt => (
										<div class="slot">
											<label>{mt.label}</label>
											<select class="meal-select" data-day={day} data-type={mt.id}>
												<option value="">Ninguno</option>
											</select>
										</div>
									))}
								</div>
							</div>
						))}
					</div>
					<div class="actions">
						<button id="save-nutrition" class="btn btn-primary">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
							Guardar Plan de Nutrición
						</button>
						<span id="nutrition-saving" class="saving-text" style="display:none;">Guardando...</span>
					</div>
				</div>

				<!-- Tab Rutina -->
				<div id="routine-tab" class="tab-content">
					<div class="tab-header">
						<h3 class="tab-title">Asignar Rutina por Día</h3>
						<div class="tab-actions">
							<button class="btn btn-outline btn-sm copy-all-routines" title="Asignar la rutina del Lunes a todos los días">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
								Copiar Lunes a Todos
							</button>
							<button class="btn btn-outline btn-sm clear-routines" title="Limpiar todas las asignaciones de rutina">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
								Limpiar Todo
							</button>
						</div>
					</div>
					<div class="days-grid">
						{days.map(day => (
							<div class="day-card glass" data-day={day}>
								<h4>{day}</h4>
								<div class="routine-slot">
									<label>Rutina</label>
									<select class="routine-select" data-day={day}>
										<option value="">Ninguna</option>
									</select>
								</div>
							</div>
						))}
					</div>
					<div class="actions">
						<button id="save-routines" class="btn btn-primary">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
							Guardar Asignación de Rutinas
						</button>
						<span id="routine-saving" class="saving-text" style="display:none;">Guardando...</span>
					</div>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>

<script>
  import '../../scripts/master-assign';
</script>

