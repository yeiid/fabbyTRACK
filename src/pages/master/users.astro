---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MasterNav from '../../components/layout/MasterNav.astro';
import PageHeader from '../../components/layout/PageHeader.astro';
import Modal from '../../components/layout/Modal.astro';
import '../../styles/master-users.css';

const session = Astro.cookies.get('user_session')?.json();
if (!session || session.role !== 'master') {
	return Astro.redirect('/login');
}
---

<BaseLayout title="Gestión de Usuarios">
	<MasterNav />
	<main class="master-users">
		<PageHeader title="Gestión de Usuarios" href="/master" linkText="Volver al Panel">
			<div class="stats-container">
				<div class="stat-card glass-card">
					<span class="stat-label">Total Clientes</span>
					<span id="total-users" class="stat-value">0</span>
				</div>
				<div class="stat-card glass-card">
					<span class="stat-label">Usuarios Activos</span>
					<span id="active-users" class="stat-value">0</span>
				</div>
			</div>
		</PageHeader>

		<!-- Barra de herramientas -->
		<section class="toolbar">
			<div class="search-box">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
				<input type="text" id="search-input" placeholder="Buscar por nombre o email...">
			</div>
			<div class="filter-group">
				<select id="filter-status">
					<option value="">Todos los planes</option>
					<option value="trial">Trial</option>
					<option value="active">Activo</option>
					<option value="expired">Expirado</option>
				</select>
				<select id="filter-active">
					<option value="">Todos</option>
					<option value="true">Activos</option>
					<option value="false">Inactivos</option>
				</select>
			</div>
			<button id="add-user-btn" class="btn btn-primary">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
				Añadir Usuario
			</button>
		</section>

		<!-- Modal Crear Usuario -->
		<Modal id="create-user-modal" title="Nuevo Usuario" maxWidth="500px">
			<form id="create-user-form" class="form-stack">
				<div class="form-group">
					<label for="new-name">Nombre Completo</label>
					<input type="text" id="new-name" name="name" placeholder="Ej: Ana García" required>
				</div>
				<div class="form-group">
					<label for="new-email">Email</label>
					<input type="email" id="new-email" name="email" placeholder="ana@email.com" required>
				</div>
				<div class="form-group">
					<label for="new-password">Contraseña</label>
					<input type="password" id="new-password" name="password" placeholder="Mínimo 6 caracteres" required>
				</div>
				<div class="form-row">
					<div class="form-group">
						<label for="new-goal">Objetivo</label>
						<select id="new-goal" name="goal">
							<option value="">Sin definir</option>
							<option value="lose_fat">Perder Grasa</option>
							<option value="gain_muscle">Ganar Músculo</option>
							<option value="maintain">Mantenimiento</option>
						</select>
					</div>
					<div class="form-group">
						<label for="new-weight">Peso (kg)</label>
						<input type="number" step="0.1" id="new-weight" name="weight_kg" placeholder="70">
					</div>
					<div class="form-group">
						<label for="new-height">Altura (cm)</label>
						<input type="number" id="new-height" name="height_cm" placeholder="170">
					</div>
				</div>
				<div id="create-feedback" class="feedback-msg" style="display: none;"></div>
				<div class="modal-actions">
					<button type="button" class="btn btn-outline modal-close">Cancelar</button>
					<button type="submit" class="btn btn-primary">Crear Usuario</button>
				</div>
			</form>
		</Modal>

		<section class="users-section">
			<div class="table-wrapper glass-card">
				<table>
					<thead>
						<tr>
							<th>Usuario</th>
							<th>Objetivo / Peso</th>
							<th>Metas Calóricas</th>
							<th>Suscripción</th>
							<th class="text-center">Acciones</th>
						</tr>
					</thead>
					<tbody id="users-tbody">
						<tr>
							<td colspan="5" class="loading-state">
								<div class="loader"></div>
								<p>Sincronizando base de datos...</p>
							</td>
						</tr>
					</tbody>
				</table>
			</div>
			<!-- Paginación -->
			<div id="pagination" class="pagination" style="display: none;">
				<button id="prev-page" class="btn btn-outline btn-sm" disabled>Anterior</button>
				<span id="page-info" class="page-info">Página 1 de 1</span>
				<button id="next-page" class="btn btn-outline btn-sm" disabled>Siguiente</button>
			</div>
		</section>
	</main>
</BaseLayout>

<script>
  import '../../scripts/master-users';
</script>

