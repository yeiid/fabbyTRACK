---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MasterNav from '../../components/layout/MasterNav.astro';

const session = Astro.cookies.get('user_session')?.json();
if (!session || session.role !== 'master') {
	return Astro.redirect('/login');
}
---

<BaseLayout title="Panel Maestro">
	<MasterNav />
	<main class="master">
		<div class="welcome">
			<h1>Bienvenido, {session.name}</h1>
			<p>Panel de control del entrenador</p>
		</div>
		
		<div class="grid">
			<a href="/master/users" class="glass-card clickable">
				<div class="card-icon">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/></svg>
				</div>
				<h2>Usuarios</h2>
				<p>Administra clientes, suscripciones y metas caloricas.</p>
			</a>
			<a href="/master/exercises" class="glass-card clickable">
				<div class="card-icon">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/></svg>
				</div>
				<h2>Ejercicios</h2>
				<p>Catalogo maestro de ejercicios con videos y tecnicas.</p>
			</a>
			<a href="/master/routines" class="glass-card clickable">
				<div class="card-icon">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
				</div>
				<h2>Rutinas</h2>
				<p>Crea rutinas combinando ejercicios del catalogo.</p>
			</a>
			<a href="/master/nutrition" class="glass-card clickable">
				<div class="card-icon">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
				</div>
				<h2>Nutricion</h2>
				<p>Recetas, macros y planes alimenticios.</p>
			</a>
			<a href="/master/assign" class="glass-card clickable highlight">
				<div class="card-icon">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
				</div>
				<h2>Asignar Planes</h2>
				<p>Asigna rutinas y nutricion personalizada a cada cliente.</p>
			</a>
		</div>
	</main>
</BaseLayout>

<style>
	.master {
		padding: var(--spacing-xl);
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-xl);
	}

	.welcome h1 {
		font-size: 2.2rem;
		background: linear-gradient(135deg, #fff, var(--primary-500));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.welcome p {
		color: var(--text-secondary);
		margin-top: var(--spacing-xs);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: var(--spacing-lg);
	}

	.clickable {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-sm);
		text-align: center;
		padding: var(--spacing-xl) !important;
		transition: all 0.3s ease;
	}

	.clickable:hover {
		transform: translateY(-5px);
		border-color: var(--primary-500);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
	}

	.highlight {
		border: 1px solid var(--border-glow);
		background: linear-gradient(135deg, rgba(124, 58, 237, 0.12) 0%, rgba(0, 0, 0, 0) 100%);
	}

	.card-icon {
		width: 56px;
		height: 56px;
		margin: 0 auto var(--spacing-sm);
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(124, 58, 237, 0.1);
		border-radius: 16px;
		color: var(--primary-500);
	}

	.clickable h2 {
		color: var(--primary-500);
		font-size: var(--text-lg);
	}

	.clickable p {
		font-size: var(--text-sm);
		color: var(--text-secondary);
		line-height: 1.4;
	}

	@media (max-width: 640px) {
		.master { padding: var(--spacing-lg); }
		.grid { grid-template-columns: 1fr 1fr; }
		.clickable { padding: var(--spacing-lg) !important; }
		.clickable h2 { font-size: var(--text-base); }
	}
</style>
