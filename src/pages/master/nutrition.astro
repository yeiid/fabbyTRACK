---
// src/pages/master/nutrition.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import MasterNav from '../../components/layout/MasterNav.astro';
import PageHeader from '../../components/layout/PageHeader.astro';
import Modal from '../../components/layout/Modal.astro';
import '../../styles/master-nutrition.css';

const session = Astro.cookies.get('user_session')?.json();
if (!session || session.role !== 'master') {
	return Astro.redirect('/login');
}
---

<BaseLayout title="Gestión de Nutrición">
	<MasterNav />
	<main class="master-nutrition">
		<PageHeader title="Catálogo de Nutrición" href="/master" linkText="Volver">
			<button id="add-meal-btn" class="btn btn-primary">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><path d="M12 5v14M5 12h14"/></svg>
				Nueva Receta
			</button>
		</PageHeader>

		<Modal id="meal-modal" title="Configurar Comida" maxWidth="550px">
			<p style="text-align: center; color: var(--text-secondary); font-size: 0.9rem; margin-bottom: var(--spacing-lg);">Añade platos equilibrados para tus planes</p>
			
			<form id="meal-form" class="form-stack">
				<div class="form-group">
					<label for="name">Nombre del Plato</label>
					<input type="text" id="name" name="name" placeholder="Ej: Bowl de Pollo y Quinoa" required>
				</div>

				<div class="form-row">
					<div class="form-group">
						<label for="meal_type">Tipo de Comida</label>
						<select id="meal_type" name="meal_type">
							<option value="breakfast">Desayuno</option>
							<option value="lunch">Almuerzo</option>
							<option value="dinner">Cena</option>
							<option value="snack">Snack / Merienda</option>
						</select>
					</div>
					<div class="form-group">
						<label for="total_calories">Calorías Totales</label>
						<input type="number" id="total_calories" name="total_calories" placeholder="Ej: 550">
					</div>
				</div>

				<div class="macros-grid">
					<div class="form-group">
						<label>Proteína (g)</label>
						<input type="number" name="protein_g" placeholder="0">
					</div>
					<div class="form-group">
						<label>Carbos (g)</label>
						<input type="number" name="carbs_g" placeholder="0">
					</div>
					<div class="form-group">
						<label>Grasas (g)</label>
						<input type="number" name="fat_g" placeholder="0">
					</div>
				</div>

				<div class="form-group">
					<label for="photo_url">URL de Imagen (Opcional)</label>
					<input type="url" id="photo_url" name="photo_url" placeholder="https://...">
				</div>

				<div class="form-group">
					<label>Ingredientes</label>
					<textarea id="ingredients-text" rows="3" placeholder="Ej: 200g Pollo, 100g Arroz..."></textarea>
				</div>

				<div class="modal-actions">
					<button type="button" class="btn btn-outline modal-close">Cancelar</button>
					<button type="submit" class="btn btn-primary">Guardar Receta</button>
				</div>
			</form>
		</Modal>

		<section class="meals-grid" id="meals-container">
			<div class="loading-state">
				<div class="loader"></div>
				<p>Cargando recetas saludables...</p>
			</div>
		</section>
	</main>
</BaseLayout>

<script>
  import '../../scripts/master-nutrition';
</script>

