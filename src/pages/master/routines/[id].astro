---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import MasterNav from '../../../components/layout/MasterNav.astro';
import Modal from '../../../components/layout/Modal.astro';

const session = Astro.cookies.get('user_session')?.json();
if (!session || session.role !== 'master') {
  return Astro.redirect('/login');
}
const { id: routineId } = Astro.params;
---

<BaseLayout title="Gestionar Rutina">
  <MasterNav />
  <main class="routine-detail" data-routine-id={routineId}>
    <header class="page-header">
      <div class="header-content">
        <a href="/master/routines" class="btn btn-outline btn-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Volver a Rutinas
        </a>
        <div>
          <h1 id="routine-name" class="gradient-text">Cargando...</h1>
          <p id="routine-desc" class="routine-subtitle"></p>
        </div>
      </div>
      <button id="add-exercise-btn" class="btn btn-primary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><path d="M12 5v14M5 12h14"/></svg>
        Agregar Ejercicio
      </button>
    </header>

    <Modal id="exercise-modal" title="Agregar Ejercicio a la Rutina">
      <form id="add-exercise-form" class="form-stack">
        <div class="form-group">
          <label for="exercise-select">Ejercicio</label>
          <select id="exercise-select" name="exercise_id" required>
            <option value="">Seleccionar ejercicio...</option>
          </select>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="sets">Series</label>
            <input type="number" id="sets" name="sets" value="3" min="1" max="20">
          </div>
          <div class="form-group">
            <label for="reps">Repeticiones</label>
            <input type="number" id="reps" name="reps" value="12" min="1" max="100">
          </div>
          <div class="form-group">
            <label for="rest_seconds">Descanso (s)</label>
            <input type="number" id="rest_seconds" name="rest_seconds" value="60" min="0" max="300">
          </div>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-outline modal-close">Cancelar</button>
          <button type="submit" class="btn btn-primary">Agregar</button>
        </div>
      </form>
    </Modal>

    <section id="exercises-container" class="exercises-section">
      <div class="loading-state">
        <div class="loader"></div>
        <p>Cargando ejercicios...</p>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const main = document.querySelector('.routine-detail')!;
  const ROUTINE_ID = Number(main.getAttribute('data-routine-id'));
  const modal = document.getElementById('exercise-modal')!;
  const form = document.getElementById('add-exercise-form') as HTMLFormElement;
  const container = document.getElementById('exercises-container')!;
  const addBtn = document.getElementById('add-exercise-btn')!;
  const nameEl = document.getElementById('routine-name')!;
  const descEl = document.getElementById('routine-desc')!;
  const exerciseSelect = document.getElementById('exercise-select') as HTMLSelectElement;

  async function loadRoutine() {
    try {
      const [routineRes, exercisesRes] = await Promise.all([
        fetch(`/api/routines/${ROUTINE_ID}`),
        fetch('/api/exercises')
      ]);
      const routine = await routineRes.json();
      const allExercises = await exercisesRes.json();

      nameEl.textContent = routine.name;
      descEl.textContent = routine.description || 'Sin descripción';

      const addedIds = new Set((routine.exercises || []).map((e: any) => e.exercise_id));
      exerciseSelect.innerHTML = '<option value="">Seleccionar ejercicio...</option>' +
        allExercises
          .filter((ex: any) => !addedIds.has(ex.id))
          .map((ex: any) => `<option value="${ex.id}">${ex.name} (${ex.muscle_group || 'General'})</option>`)
          .join('');

      renderExercises(routine.exercises || []);
    } catch (error) {
      container.innerHTML = '<div class="error-state">Error al cargar rutina.</div>';
    }
  }

  function renderExercises(exercises: any[]) {
    if (exercises.length === 0) {
      container.innerHTML = `
        <div class="empty-state">
          <p>Esta rutina no tiene ejercicios. Agrega tu primer ejercicio.</p>
        </div>
      `;
      return;
    }

    container.innerHTML = `
      <div class="exercise-grid">
        ${exercises.map((ex: any, i: number) => `
          <div class="ex-card glass-card" data-exercise-id="${ex.exercise_id}">
            <div class="ex-order">${i + 1}</div>
            <div class="ex-info">
              <h3>${ex.name}</h3>
              <div class="ex-tags">
                <span class="muscle-tag">${ex.muscle_group || 'General'}</span>
                <span class="diff-tag ${ex.difficulty}">${ex.difficulty === 'beginner' ? 'Principiante' : ex.difficulty === 'intermediate' ? 'Intermedio' : 'Avanzado'}</span>
              </div>
              ${ex.exercise_description ? `<p class="ex-desc">${ex.exercise_description}</p>` : ''}
            </div>
            <div class="ex-config">
              <div class="config-item">
                <label>Series</label>
                <span class="config-val">${ex.sets}</span>
              </div>
              <div class="config-item">
                <label>Reps</label>
                <span class="config-val">${ex.reps}</span>
              </div>
              <div class="config-item">
                <label>Descanso</label>
                <span class="config-val">${ex.rest_seconds}s</span>
              </div>
            </div>
            <button class="btn-remove" title="Quitar de la rutina">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
          </div>
        `).join('')}
      </div>
    `;

    container.querySelectorAll('.btn-remove').forEach((btn, i) => {
      (btn as HTMLElement).onclick = () => removeExercise(exercises[i].exercise_id);
    });
  }

  async function removeExercise(exerciseId: number) {
    if (!confirm('¿Quitar este ejercicio de la rutina?')) return;
    try {
      const response = await fetch(`/api/routines/${ROUTINE_ID}/exercises`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ exercise_id: exerciseId })
      });
      if (response.ok) loadRoutine();
    } catch (error) {
      console.error('Remove error:', error);
    }
  }

  addBtn.onclick = () => { modal.style.display = 'flex'; };

  form.onsubmit = async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const response = await fetch(`/api/routines/${ROUTINE_ID}/exercises`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          exercise_id: Number(data.exercise_id),
          sets: Number(data.sets),
          reps: Number(data.reps),
          rest_seconds: Number(data.rest_seconds),
        })
      });
      if (response.ok) {
        modal.style.display = 'none';
        loadRoutine();
      }
    } catch (error) {
      console.error('Add exercise error:', error);
    }
  };

  loadRoutine();
</script>

<style is:global>
  .routine-detail {
    padding: var(--spacing-xl);
    max-width: 1300px;
    margin: 0 auto;
    color-scheme: dark;
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--spacing-xl);
    gap: var(--spacing-lg);
    flex-wrap: wrap;
  }

  .header-content {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    flex: 1;
    flex-wrap: wrap;
    min-width: 0;
  }

  .gradient-text {
    font-size: 2.5rem;
    background: linear-gradient(135deg, #fff 0%, var(--primary-500) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .routine-subtitle {
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .exercise-grid {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .ex-card {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-lg);
    padding: var(--spacing-lg) !important;
    border: 1px solid var(--border-subtle);
    transition: border-color 0.2s ease;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.03);
  }

  .ex-card:hover {
    border-color: var(--primary-500);
  }

  .ex-order {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--primary-500);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 0.95rem;
    flex-shrink: 0;
  }

  .ex-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .ex-info h3 {
    font-size: 1.1rem;
    min-width: 0;
  }

  .ex-tags {
    display: flex;
    gap: var(--spacing-sm);
    font-size: 0.7rem;
    flex-wrap: wrap;
  }

  .muscle-tag {
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .ex-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: 4px;
  }

  .ex-config {
    display: grid;
    grid-template-columns: repeat(3, minmax(80px, 1fr));
    gap: var(--spacing-md);
    flex-shrink: 0;
    min-width: 220px;
  }

  .config-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .config-item label {
    font-size: 0.65rem;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .config-val {
    font-size: 1.1rem;
    font-weight: 700;
    font-family: 'Outfit', sans-serif;
    color: var(--primary-500);
  }

  .btn-remove {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(239, 68, 68, 0.1);
    color: var(--danger-500);
    border: 1px solid rgba(239, 68, 68, 0.2);
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .btn-remove:hover {
    background: var(--danger-500);
    color: white;
  }

	.form-group select {
		color-scheme: dark;
	}

	.form-group select option {
		background: #1a1a2e;
		color: #f8fafc;
	}

	.form-row {
		display: grid;
		grid-template-columns: repeat(3, minmax(120px, 1fr));
		gap: var(--spacing-md);
	}

  .loading-state, .empty-state, .error-state {
    padding: 5rem;
    text-align: center;
    color: var(--text-secondary);
  }

  @media (max-width: 900px) {
    .routine-detail {
      padding: var(--spacing-lg);
    }

    .page-header {
      flex-direction: column;
      align-items: stretch;
    }

    .header-content {
      justify-content: space-between;
    }

    .exercise-grid {
      gap: var(--spacing-md);
    }

    .ex-card {
      flex-direction: column;
      align-items: stretch;
    }

    .ex-config {
      width: 100%;
      min-width: auto;
      grid-template-columns: repeat(2, minmax(100px, 1fr));
    }

    .btn-remove {
      margin-top: var(--spacing-md);
      align-self: flex-end;
    }
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .ex-config {
      grid-template-columns: 1fr;
    }

    .page-header {
      gap: var(--spacing-sm);
    }
  }
</style>
