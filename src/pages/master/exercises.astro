---
// src/pages/master/exercises.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import MasterNav from '../../components/layout/MasterNav.astro';
import PageHeader from '../../components/layout/PageHeader.astro';
import Modal from '../../components/layout/Modal.astro';

const session = Astro.cookies.get('user_session')?.json();
if (!session || session.role !== 'master') {
	return Astro.redirect('/login');
}
---

<BaseLayout title="Catálogo de Ejercicios">
	<MasterNav />
	<main class="master-exercises">
		<PageHeader title="Catálogo de Ejercicios" href="/master" linkText="Panel Principal">
			<button id="add-exercise-btn" class="btn btn-primary">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><path d="M12 5v14M5 12h14"/></svg>
				Añadir Ejercicio
			</button>
		</PageHeader>

		<Modal id="exercise-modal" title="Configurar Ejercicio" maxWidth="600px">
			<p class="modal-subtitle">Define la técnica y los recursos para tus clientes</p>
			
			<form id="exercise-form" class="form-stack">
				<input type="hidden" id="exercise-id" name="id">
				
				<div class="form-group">
					<label for="name">Nombre del Ejercicio</label>
					<input type="text" id="name" name="name" placeholder="Ej: Sentadilla Búlgara" required>
				</div>

				<div class="form-row">
					<div class="form-group">
						<label for="muscle_group">Grupo Muscular</label>
						<select id="muscle_group" name="muscle_group">
							<option value="Piernas">Piernas</option>
							<option value="Espalda">Espalda</option>
							<option value="Pecho">Pecho</option>
							<option value="Hombros">Hombros</option>
							<option value="Brazos">Brazos</option>
							<option value="Core">Core</option>
						</select>
					</div>
					<div class="form-group">
						<label for="difficulty">Dificultad</label>
						<select id="difficulty" name="difficulty">
							<option value="beginner">Principiante</option>
							<option value="intermediate">Intermedio</option>
							<option value="advanced">Avanzado</option>
						</select>
					</div>
				</div>

				<div class="form-group">
					<label for="youtube_url">Link de Video (Drive o YouTube Privado)</label>
					<div class="input-with-info">
						<input type="url" id="youtube_url" name="youtube_url" placeholder="https://drive.google.com/file/d/...">
						<small class="info-text">Sube tu video a Drive y pega aquí el enlace de "Compartir" con acceso de lector.</small>
					</div>
				</div>

				<div class="form-group">
					<label for="description">Descripción Técnica</label>
					<textarea id="description" name="description" rows="2" placeholder="Explica brevemente para qué sirve este ejercicio"></textarea>
				</div>

				<div class="form-group">
					<label for="recommendation">Consejos de Seguridad</label>
					<textarea id="recommendation" name="recommendation" rows="2" placeholder="Ej: Mantener el core contraído y evitar rebotar..."></textarea>
				</div>

				<div class="modal-actions">
					<button type="button" class="btn btn-outline modal-close">Cancelar</button>
					<button type="submit" class="btn btn-primary">Guardar Catálogo</button>
				</div>
			</form>
		</Modal>

		<section class="exercises-grid" id="exercises-container">
			<div class="loading-state">
				<div class="loader"></div>
				<p>Cargando biblioteca de movimientos...</p>
			</div>
		</section>
	</main>
</BaseLayout>

<script>
	const modal = document.getElementById('exercise-modal')!;
	const form = document.getElementById('exercise-form') as HTMLFormElement;
	const container = document.getElementById('exercises-container')!;
	const addBtn = document.getElementById('add-exercise-btn')!;
	const modalTitle = modal.querySelector('h2')!;

	async function fetchExercises() {
		try {
			const response = await fetch('/api/exercises');
			const exercises = await response.json();

			if (exercises.length === 0) {
				container.innerHTML = `
					<div class="empty-state">
						<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
						<p>Tu catálogo está vacío. Comienza añadiendo tu primer ejercicio.</p>
					</div>
				`;
				return;
			}

			container.innerHTML = exercises.map((ex: any) => `
				<div class="exercise-card glass-card" data-id="${ex.id}">
					<div class="card-top">
						<span class="muscle-badge">${ex.muscle_group || 'General'}</span>
						<div class="action-icons">
							<button class="icon-btn-edit" title="Editar">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
							</button>
							<button class="icon-btn-delete" title="Eliminar">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
							</button>
						</div>
					</div>
					<div class="card-content">
						<h3>${ex.name}</h3>
						<p class="ex-description">${ex.description || 'Sin descripción detallada'}</p>
					</div>
					<div class="card-footer">
						<span class="diff-indicator ${ex.difficulty}">${ex.difficulty === 'beginner' ? 'Principiante' : ex.difficulty === 'intermediate' ? 'Intermedio' : 'Avanzado'}</span>
						${ex.youtube_url ? `
							<a href="${ex.youtube_url}" target="_blank" class="video-link">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
								Video
							</a>
						` : '<span class="no-video">Sin video</span>'}
					</div>
				</div>
			`).join('');

			document.querySelectorAll('.icon-btn-edit').forEach((btn, i) => {
				(btn as HTMLElement).onclick = () => editExercise(exercises[i]);
			});
			document.querySelectorAll('.icon-btn-delete').forEach((btn, i) => {
				(btn as HTMLElement).onclick = () => deleteExercise(exercises[i].id);
			});
		} catch (error) {
			container.innerHTML = '<div class="error-state">Error al cargar la biblioteca. Intenta de nuevo.</div>';
		}
	}

	function editExercise(ex: any) {
		modalTitle.textContent = 'Editar Ejercicio';
		(document.getElementById('exercise-id') as HTMLInputElement).value = ex.id;
		(document.getElementById('name') as HTMLInputElement).value = ex.name;
		(document.getElementById('muscle_group') as HTMLSelectElement).value = ex.muscle_group || 'Piernas';
		(document.getElementById('difficulty') as HTMLSelectElement).value = ex.difficulty || 'beginner';
		(document.getElementById('youtube_url') as HTMLInputElement).value = ex.youtube_url || '';
		(document.getElementById('description') as HTMLTextAreaElement).value = ex.description || '';
		(document.getElementById('recommendation') as HTMLTextAreaElement).value = ex.recommendation || '';
		modal.style.display = 'flex';
	}

	async function deleteExercise(id: number) {
		if (!confirm('¿Estás seguro de eliminar este ejercicio?')) return;
		try {
			const response = await fetch(`/api/exercises/${id}`, { method: 'DELETE' });
			if (response.ok) fetchExercises();
		} catch (error) {
			console.error('Delete error:', error);
		}
	}

	addBtn.onclick = () => {
		form.reset();
		(document.getElementById('exercise-id') as HTMLInputElement).value = '';
		modalTitle.textContent = 'Nuevo Ejercicio';
		modal.style.display = 'flex';
	};

	form.onsubmit = async (e) => {
		e.preventDefault();
		const formData = new FormData(form);
		const data = Object.fromEntries(formData);
		const id = data.id;

		const url = id ? `/api/exercises/${id}` : '/api/exercises';
		const method = id ? 'PATCH' : 'POST';

		try {
			const response = await fetch(url, {
				method,
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(data)
			});

			if (response.ok) {
				modal.style.display = 'none';
				fetchExercises();
			} else {
				const err = await response.json();
				alert(err.message || 'Error al guardar el ejercicio');
			}
		} catch (error) {
			console.error('Save error:', error);
		}
	};

	fetchExercises();
</script>

<style is:global>
	.master-exercises {
		padding: var(--spacing-xl);
		max-width: 1300px;
		margin: 0 auto;
		animation: fadeIn 0.5s ease;
		color-scheme: dark;
	}

	.exercises-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: var(--spacing-lg);
	}

	.exercise-card {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-md);
		border: 1px solid var(--border-subtle);
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		position: relative;
		overflow: hidden;
	}

	.exercise-card:hover {
		transform: translateY(-5px);
		border-color: var(--primary-500);
		box-shadow: 0 12px 24px rgba(0,0,0,0.3);
	}

	.card-top {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.muscle-badge {
		background: rgba(124, 58, 237, 0.1);
		color: var(--primary-500);
		padding: 4px 10px;
		border-radius: 6px;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.action-icons {
		display: flex;
		gap: 8px;
	}

	.exercise-card h3 {
		font-size: 1.25rem;
		margin: 0;
	}

	.ex-description {
		font-size: 0.9rem;
		color: var(--text-secondary);
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		min-height: 2.7rem;
	}

	.card-footer {
		margin-top: auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: var(--spacing-md);
		border-top: 1px solid var(--border-subtle);
	}

	.video-link {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 0.85rem;
		color: var(--primary-500);
		font-weight: 600;
	}

	.no-video {
		font-size: 0.8rem;
		color: var(--text-muted);
	}

	.modal-subtitle {
		font-size: 0.9rem;
		color: var(--text-secondary);
	}

	.form-group select option {
		background: #1a1a2e;
		color: #f8fafc;
	}

	.info-text {
		display: block;
		margin-top: 4px;
		font-size: 0.75rem;
		color: var(--text-muted);
		font-style: italic;
	}

	.input-with-info input {
		width: 100%;
	}

	.loading-state, .empty-state, .error-state {
		grid-column: 1 / -1;
	}

	@media (max-width: 640px) {
		.page-header { flex-direction: column; align-items: stretch; gap: var(--spacing-md); }
		.exercises-grid { grid-template-columns: 1fr; }
	}
</style>
